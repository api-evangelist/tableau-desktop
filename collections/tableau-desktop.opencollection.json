      },
      "items": [
        {
          "info": {
            "name": "Query Sites",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{tableau-server}/api/3.22/sites"
          },
          "docs": "Returns a list of sites on the server."
